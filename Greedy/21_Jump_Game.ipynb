   "source": [
    "class Solution:\n",
    "    def canJump(self, nums: List[int]) -> bool:\n",
    "        max_jump = 0\n",
    "\n",
    "        for i in range(len(nums)):\n",
    "            if i > max_jump:\n",
    "                return False\n",
    "            max_jump = max(max_jump, i + nums[i])\n",
    "\n",
    "        return True"
   ]
  }
