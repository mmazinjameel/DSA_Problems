   "source": [
    "class Solution:\n",
    "    def minChanges(self, s: str) -> int:\n",
    "        ans = 0\n",
    "\n",
    "        for i in range(0, len(s), 2):\n",
    "            if s[i] != s[i + 1]:\n",
    "                ans += 1\n",
    "\n",
    "        return ans"
   ]
  }
