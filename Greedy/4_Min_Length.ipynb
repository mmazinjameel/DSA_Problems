   "source": [
    "class Solution:\n",
    "    def minimumLength(self, s: str) -> int:\n",
    "        res = 0\n",
    "\n",
    "        for cnt in Counter(s).values():\n",
    "            if cnt%2 == 1:\n",
    "                res += 1\n",
    "            else:\n",
    "                res += 2\n",
    "\n",
    "        return res"
   ]
  }
 ],
