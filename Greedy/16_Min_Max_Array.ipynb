   "source": [
    "class Solution:\n",
    "    def minimizeArrayValue(self, nums: List[int]) -> int:\n",
    "        ans = 0\n",
    "        prefix = 0\n",
    "\n",
    "        for i, num in enumerate(nums):\n",
    "            prefix += num\n",
    "\n",
    "            ans = max(ans, (prefix + i) // (i + 1))\n",
    "\n",
    "        return ans"
   ]
  }
