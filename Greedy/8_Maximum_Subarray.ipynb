   "source": [
    "class Solution:\n",
    "    def maxSubArray(self, nums: List[int]) -> int:\n",
    "\n",
    "        max_sum = nums[0]\n",
    "        cur_sum = nums[0]\n",
    "\n",
    "        for n in nums[1:]:\n",
    "            cur_sum = max(n, cur_sum + n)\n",
    "            max_sum = max(max_sum, cur_sum)\n",
    "        \n",
    "        return max_sum\n"
   ]
  }
 ],
